# 모든 텍스트 파일 LF 통일 — Windows/Mac/Linux 작업 환경 혼재 방지.
# 이 설정 없으면 Windows 에서 git autocrlf 가 LF→CRLF 변환해서 PR diff 가 노이즈로 가득 참.

* text=auto eol=lf

# Source / config
*.kt           text eol=lf
*.kts          text eol=lf
*.java         text eol=lf
*.gradle       text eol=lf
*.xml          text eol=lf
*.md           text eol=lf
*.json         text eol=lf
*.yml          text eol=lf
*.yaml         text eol=lf
*.properties   text eol=lf
*.pro          text eol=lf
*.sh           text eol=lf
*.ts           text eol=lf
*.tsx          text eol=lf
*.js           text eol=lf
*.mjs          text eol=lf

# Windows 전용 스크립트는 CRLF 유지
*.bat          text eol=crlf
*.cmd          text eol=crlf

# Binary
*.png          binary
*.jpg          binary
*.jpeg         binary
*.gif          binary
*.webp         binary
*.ico          binary
*.pdf          binary
*.zip          binary
*.jar          binary
*.apk          binary
*.aab          binary
*.keystore     binary
*.jks          binary
*.m4a          binary
*.amr          binary
*.3gp          binary
gradlew        text eol=lf
