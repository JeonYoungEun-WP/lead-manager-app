<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- 전화 걸기 -->
    <uses-permission android:name="android.permission.CALL_PHONE" />

    <!-- 통화 상태 감지 (통화 종료 후 녹음 파일 스캔 트리거) -->
    <uses-permission android:name="android.permission.READ_PHONE_STATE" />

    <!-- 통화 기록 조회 (녹음 파일 타임스탬프 → 번호 매핑) -->
    <uses-permission android:name="android.permission.READ_CALL_LOG" />

    <!-- SMS 발송 (기본 SMS 앱 인텐트 호출용이라 실제로는 불필요하지만 명시) -->
    <!-- <uses-permission android:name="android.permission.SEND_SMS" /> -->

    <!-- 포그라운드 서비스 (장기 STT 작업 시) -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />

    <!-- 인터넷 (Gemini 프록시 호출) -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- 알림 (Android 13+ 에서 명시 필요) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- 부팅 후 WorkManager 재실행 -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- 배터리 최적화 예외 다이얼로그 (Doze 모드 회피로 통화 즉시 감지 안정화) -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />

    <!-- 저장소 직접 접근 안 함 — SAF(Storage Access Framework) 로 사용자가 선택한 폴더만 접근 -->

    <application
        android:name=".LeadApp"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.BoosterLeadApp"
        tools:targetApi="34">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.BoosterLeadApp">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- 재연락 약속 시각에 NotificationManager 로 알림 발행 -->
        <receiver
            android:name=".service.CallbackAlarmReceiver"
            android:exported="false" />
    </application>

    <!-- 다른 앱 호출 대상 선언 (Android 11+ package visibility) -->
    <queries>
        <!-- 전화 앱 -->
        <intent>
            <action android:name="android.intent.action.CALL" />
            <data android:scheme="tel" />
        </intent>
        <!-- SMS 앱 -->
        <intent>
            <action android:name="android.intent.action.SENDTO" />
            <data android:scheme="smsto" />
        </intent>
    </queries>

</manifest>
