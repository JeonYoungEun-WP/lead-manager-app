# Gemini 2.5 Flash - 핵심 요약 생성에 사용
GOOGLE_GENERATIVE_AI_API_KEY=

# RTZR (Vito) STT OpenAPI - 음성 → 전문 텍스트 변환
# https://developers.rtzr.ai/console/
RTZR_CLIENT_ID=
RTZR_CLIENT_SECRET=

# Vercel Blob - 대용량 파일(>4.5MB) 직접 업로드 스토어
# Vercel 대시보드 Storage → Blob 스토어 생성 → 프로젝트 연결 시 자동 주입
BLOB_READ_WRITE_TOKEN=
